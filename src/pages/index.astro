---
// src/pages/index.astro
import LooseWireLayout from '../layouts/LooseWireLayout.astro';
import Logo from '../components/loosewire/Logo.astro';
import HarknotesLogo from '../components/harknotes/Logo.astro';
import FarscryLogo from '../components/farscry/Logo.astro';
import UncloudedLogo from '../components/unclouded/Logo.astro';
---
<LooseWireLayout
  title="Loose Wire — Independent dev, shipping products"
  description="Making the software I wish existed. One person, multiple products. Currently: Harknotes, Farscry, and Unclouded."
>

  <!-- ─── Topbar ──────────────────────────────────────────── -->
  <div class="page">
    <header class="topbar">
      <a href="/" class="topbar-id" aria-label="Home">
        <Logo size={32} />
        <span class="topbar-name">loosewire</span>
      </a>
      <nav class="topbar-nav">
        <a href="/blog">Blog</a>
        <a href="https://github.com/LooseWireDev" target="_blank" rel="noopener">GitHub</a>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle light/dark">
          <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
          <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </nav>
    </header>

    <!-- ─── Hero ────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-mark anim" style="animation-delay: 0.05s">
        <Logo size={200} />
      </div>

      <h1 class="hero-heading anim" style="animation-delay: 0.12s">
        loose<br>wire.
      </h1>

      <p class="hero-label anim" style="animation-delay: 0.18s">
        LLC &middot; Independent dev &middot; 2026
      </p>

      <p class="hero-prose anim" style="animation-delay: 0.24s">
        I build the software I wish existed. One person. Multiple products.
        Each one solves a single problem and stays out of the way.
      </p>
    </section>

    <hr class="rule anim" style="animation-delay: 0.3s" />

    <!-- ─── Products ─────────────────────────────────────────── -->
    <section class="products">
      <p class="section-label anim" style="animation-delay: 0.34s">01 &mdash; Products</p>

      <!-- Harknotes -->
      <a href="/harknotes" class="product-card anim" style="animation-delay: 0.38s">
        <div class="product-card-top">
          <div class="product-card-identity">
            <span class="product-dot" style="background: #3dd68c;"></span>
            <span class="product-name">Harknotes</span>
          </div>
          <HarknotesLogo size={28} />
        </div>

        <p class="product-meta">macOS &middot; Linux &middot; Free / $6 / $12 per month</p>

        <p class="product-desc">
          Private meeting transcription. No bot joins your calls.
          Audio captured at the OS level, transcribed locally with whisper.cpp.
          Only the text ever leaves your machine.
        </p>

        <span class="product-cta" style="color: #3dd68c;">
          Learn more &rarr;
        </span>
      </a>

      <!-- Farscry -->
      <a href="/farscry" class="product-card anim" style="animation-delay: 0.44s">
        <div class="product-card-top">
          <div class="product-card-identity">
            <span class="product-dot" style="background: #6c8ebf;"></span>
            <span class="product-name">Farscry</span>
          </div>
          <FarscryLogo size={28} />
        </div>

        <p class="product-meta">iOS &middot; Android &middot; Self-hosted &middot; Coming soon</p>

        <p class="product-desc">
          Private video calling. No chat, no bloat. End-to-end encrypted,
          self-hostable, open source. One Docker container is all it takes.
        </p>

        <span class="product-cta" style="color: #6c8ebf;">
          Learn more &rarr;
        </span>
      </a>
      <!-- Unclouded -->
      <a href="/unclouded" class="product-card anim" style="animation-delay: 0.50s">
        <div class="product-card-top">
          <div class="product-card-identity">
            <span class="product-dot" style="background: #EDD06A;"></span>
            <span class="product-name">Unclouded</span>
          </div>
          <UncloudedLogo size={28} />
        </div>

        <p class="product-meta">Web &middot; Mobile (planned) &middot; Free</p>

        <p class="product-desc">
          Privacy-focused app discovery and comparison. Find open-source
          alternatives to the apps you use, compare them honestly, and generate
          Obtainium configs to make the switch.
        </p>

        <span class="product-cta" style="color: #EDD06A;">
          Learn more &rarr;
        </span>
      </a>
    </section>

    <hr class="rule anim" style="animation-delay: 0.56s" />

    <!-- ─── About ─────────────────────────────────────────────── -->
    <section class="about anim" style="animation-delay: 0.54s">
      <p class="section-label">Contact</p>
      <p class="about-body">
        Made by Gav &mdash; <a href="mailto:info@loosewire.dev" class="inline-link">info@loosewire.dev</a>
      </p>
    </section>

    <!-- ─── Footer ───────────────────────────────────────────── -->
    <footer class="footer anim" style="animation-delay: 0.58s">
      <div class="footer-left">
        <Logo size={28} />
        <span class="footer-url">loosewire.dev</span>
      </div>
      <div class="footer-right">
        <a href="/blog">Blog</a>
        <a href="/harknotes">Harknotes</a>
        <a href="/farscry">Farscry</a>
        <a href="/unclouded">Unclouded</a>
        <span class="footer-copy">&copy; {new Date().getFullYear()} Loose Wire LLC</span>
      </div>
    </footer>
  </div>

<script>
  const btn = document.getElementById('themeToggle');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const next = isDark ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('lw-theme', next);
  });
</script>
</LooseWireLayout>

<style>
  /* ─── Page wrapper ──────────────────────────────────── */
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 32px 120px;
    position: relative;
    z-index: 1;
  }

  /* ─── Topbar ────────────────────────────────────────── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--lw-paper);
    border-bottom: 1px solid var(--lw-rule-strong);
    padding: 10px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .topbar-id {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .topbar-name {
    font-family: var(--lw-font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--lw-ink);
  }
  .topbar-nav {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .topbar-nav a {
    font-family: var(--lw-font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lw-ash);
    text-decoration: none;
    transition: color 0.12s;
  }
  .topbar-nav a:hover {
    color: var(--lw-ink);
  }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: none;
    border: 1px solid var(--lw-rule-strong);
    border-radius: 6px;
    color: var(--lw-ash);
    cursor: pointer;
    padding: 0;
    transition: color 0.12s, border-color 0.12s;
  }
  .theme-toggle:hover {
    color: var(--lw-ink);
    border-color: var(--lw-graphite);
  }
  /* Show sun in dark mode, moon in light mode */
  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }

  /* ─── Hero ──────────────────────────────────────────── */
  .hero {
    padding: 80px 0 60px;
  }
  .hero-mark {
    margin-bottom: 32px;
  }
  .hero-heading {
    font-family: var(--lw-font-display);
    font-size: clamp(52px, 10vw, 72px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.92;
    color: var(--lw-ink);
    margin-bottom: 18px;
  }
  .hero-label {
    font-family: var(--lw-font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lw-dust);
    margin-bottom: 24px;
  }
  .hero-prose {
    font-family: var(--lw-font-prose);
    font-style: italic;
    font-size: 16px;
    line-height: 1.8;
    color: var(--lw-graphite);
    max-width: 520px;
    border-left: 2px solid var(--lw-rule-strong);
    padding-left: 18px;
  }

  /* ─── Horizontal rule ────────────────────────────────── */
  .rule {
    border: none;
    border-top: 1px solid var(--lw-rule-strong);
    margin: 56px 0;
  }

  /* ─── Section label ──────────────────────────────────── */
  .section-label {
    font-family: var(--lw-font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lw-dust);
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--lw-rule-strong);
  }

  /* ─── Products ───────────────────────────────────────── */
  .products {
    padding-bottom: 0;
  }

  .product-card {
    display: block;
    background: var(--lw-paper-2);
    border: 1px solid var(--lw-rule-strong);
    border-radius: 12px;
    padding: 28px 32px;
    text-decoration: none;
    margin-bottom: 8px;
    transition: border-color 0.15s, background 0.15s;
  }
  .product-card:hover {
    background: var(--lw-paper-3);
  }

  .product-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .product-card-identity {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .product-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .product-name {
    font-family: var(--lw-font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--lw-ink);
  }
  .product-meta {
    font-family: var(--lw-font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--lw-ash);
    margin-bottom: 14px;
  }
  .product-desc {
    font-family: var(--lw-font-display);
    font-size: 14px;
    line-height: 1.7;
    color: var(--lw-graphite);
    margin-bottom: 18px;
  }
  .product-cta {
    font-family: var(--lw-font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  /* ─── About ──────────────────────────────────────────── */
  .about {
    padding-bottom: 0;
  }
  .about-body {
    font-family: var(--lw-font-display);
    font-size: 14px;
    line-height: 1.75;
    color: var(--lw-graphite);
    max-width: 560px;
  }
  .inline-link {
    color: var(--lw-graphite);
    text-decoration: underline;
    text-decoration-color: var(--lw-dust);
    text-underline-offset: 3px;
  }
  .inline-link:hover {
    color: var(--lw-ink);
  }

  /* ─── Footer ─────────────────────────────────────────── */
  .footer {
    margin-top: 60px;
    padding-top: 20px;
    border-top: 1px solid var(--lw-rule-strong);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .footer-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer-url {
    font-family: var(--lw-font-mono);
    font-size: 10px;
    letter-spacing: 0.10em;
    color: var(--lw-dust);
  }
  .footer-right {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-right a {
    font-family: var(--lw-font-mono);
    font-size: 10px;
    letter-spacing: 0.10em;
    color: var(--lw-ash);
    text-decoration: none;
    transition: color 0.12s;
  }
  .footer-right a:hover {
    color: var(--lw-ink);
  }
  .footer-copy {
    font-family: var(--lw-font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--lw-dust);
  }

  /* ─── Animations ──────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .anim {
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
  }
</style>
