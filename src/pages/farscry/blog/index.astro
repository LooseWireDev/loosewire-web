---
// src/pages/farscry/blog/index.astro
import FarscryLayout from '../../../layouts/FarscryLayout.astro';
import { getCollection } from 'astro:content';
import Nav from '../../../components/farscry/Nav.astro';
import Footer from '../../../components/farscry/Footer.astro';

const posts = (await getCollection('farscry-blog')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---
<FarscryLayout
  title="Farscry Blog — Private Video Calling & Self-Hosting"
  description="Articles on end-to-end encrypted video calling, self-hosting, and building privacy-first communication tools."
>
  <Nav />

  <main style="max-width: 720px; margin: 0 auto; padding: 64px 32px;">
    <h1 style="font-size: clamp(28px, 4vw, 40px); font-weight: 700; letter-spacing: -0.03em; color: var(--fc-text-primary); margin-bottom: 8px;">Blog</h1>
    <p style="font-size: 16px; color: var(--fc-text-secondary); margin-bottom: 48px; line-height: 1.6;">
      Articles on private video calling, self-hosting, and why your calls should belong to you.
    </p>

    {posts.length === 0 && (
      <p style="color: var(--fc-text-tertiary);">Articles coming soon.</p>
    )}

    <div style="display: flex; flex-direction: column; gap: 0;">
      {posts.map(post => (
        <a href={`/farscry/blog/${post.slug}`}
           style="display: block; padding: 28px 0; border-bottom: 1px solid var(--fc-border-subtle); text-decoration: none;">
          <p style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--fc-text-tertiary); margin-bottom: 8px;">{post.data.pubDate}</p>
          <h2 style="font-size: 18px; font-weight: 600; color: var(--fc-text-primary); margin-bottom: 8px; letter-spacing: -0.02em;">{post.data.title}</h2>
          <p style="font-size: 14px; color: var(--fc-text-secondary); line-height: 1.6;">{post.data.description}</p>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</FarscryLayout>
