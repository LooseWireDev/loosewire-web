---
import LooseWireLayout from '../layouts/LooseWireLayout.astro';
---
<LooseWireLayout
  title="Page not found — Loose Wire"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <main style="max-width: 520px; margin: 0 auto; padding: 120px 32px; text-align: center;">
    <p style="font-family: var(--lw-font-mono); font-size: 64px; font-weight: 800; color: var(--lw-ink); margin-bottom: 16px;">404</p>
    <h1 style="font-family: var(--lw-font-display); font-size: 24px; font-weight: 700; color: var(--lw-ink); margin-bottom: 12px;">
      Page not found
    </h1>
    <p style="font-size: 16px; color: var(--lw-graphite); margin-bottom: 40px; line-height: 1.6;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <a href="/" style="font-family: var(--lw-font-mono); font-size: 13px; font-weight: 500; color: var(--lw-ink); text-decoration: underline; text-underline-offset: 3px;">Home</a>
      <a href="/harknotes" style="font-family: var(--lw-font-mono); font-size: 13px; font-weight: 500; color: var(--lw-ink); text-decoration: underline; text-underline-offset: 3px;">Harknotes</a>
      <a href="/farscry" style="font-family: var(--lw-font-mono); font-size: 13px; font-weight: 500; color: var(--lw-ink); text-decoration: underline; text-underline-offset: 3px;">Farscry</a>
      <a href="/unclouded" style="font-family: var(--lw-font-mono); font-size: 13px; font-weight: 500; color: var(--lw-ink); text-decoration: underline; text-underline-offset: 3px;">Unclouded</a>
      <a href="/mealforge" style="font-family: var(--lw-font-mono); font-size: 13px; font-weight: 500; color: var(--lw-ink); text-decoration: underline; text-underline-offset: 3px;">Mealforge</a>
      <a href="/blog" style="font-family: var(--lw-font-mono); font-size: 13px; font-weight: 500; color: var(--lw-ink); text-decoration: underline; text-underline-offset: 3px;">Blog</a>
    </div>
  </main>
</LooseWireLayout>
