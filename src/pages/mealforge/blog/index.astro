---
// src/pages/mealforge/blog/index.astro
import MealforgeLayout from '../../../layouts/MealforgeLayout.astro';
import { getCollection } from 'astro:content';
import Nav from '../../../components/mealforge/Nav.astro';
import Footer from '../../../components/mealforge/Footer.astro';

const posts = (await getCollection('mealforge-blog')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---
<MealforgeLayout
  title="Mealforge Blog — Self-Hosted, AI-Planned Meals"
  description="Articles on self-hosted meal planning, planning your week with AI over MCP, and owning your kitchen data."
>
  <Nav />

  <main style="max-width: 720px; margin: 0 auto; padding: 64px 32px;">
    <h1 style="font-family: var(--mf-font-display); font-size: clamp(28px, 4vw, 40px); font-weight: 600; letter-spacing: -0.02em; color: var(--mf-text); margin-bottom: 8px;">Blog</h1>
    <p style="font-size: 16px; color: var(--mf-text-mid); margin-bottom: 48px; line-height: 1.6;">
      Articles on self-hosted meal planning, AI planning over MCP, and keeping your kitchen out of the cloud.
    </p>

    {posts.length === 0 && (
      <p style="color: var(--mf-text-dim);">Articles coming soon.</p>
    )}

    <div style="display: flex; flex-direction: column; gap: 0;">
      {posts.map(post => (
        <a href={`/mealforge/blog/${post.slug}`}
           style="display: block; padding: 28px 0; border-bottom: 1px solid var(--mf-border); text-decoration: none;">
          <p style="font-family: var(--mf-font-mono); font-size: 11px; color: var(--mf-text-dim); margin-bottom: 8px;">{post.data.pubDate}</p>
          <h2 style="font-family: var(--mf-font-display); font-size: 18px; font-weight: 600; color: var(--mf-text); margin-bottom: 8px; letter-spacing: -0.01em;">{post.data.title}</h2>
          <p style="font-size: 14px; color: var(--mf-text-mid); line-height: 1.6;">{post.data.description}</p>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</MealforgeLayout>
