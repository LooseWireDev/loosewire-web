---
// src/components/blog/Callout.astro
import { Icon } from 'astro-icon/components';

interface Props {
  type?: 'info' | 'tip' | 'warning';
  title?: string;
}

const { type = 'info', title } = Astro.props;
const iconNames = { info: 'lucide:info', tip: 'lucide:lightbulb', warning: 'lucide:triangle-alert' };
---
<aside class:list={[`callout callout--${type}`]}>
  <div class="callout-header">
    <Icon name={iconNames[type]} class="callout-icon" />
    {title && <span class="callout-title">{title}</span>}
  </div>
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    border-radius: 12px;
    padding: 20px 24px;
    margin: 24px 0;
    font-size: 14px;
    line-height: 1.6;
  }
  .callout--info {
    background: var(--blog-surface-2);
    border: 1px solid var(--blog-border);
  }
  .callout--tip {
    background: var(--blog-accent-subtle);
    border: 1px solid var(--blog-accent-border);
  }
  .callout--warning {
    background: rgba(245,158,11,0.12);
    border: 1px solid rgba(245,158,11,0.2);
  }
  .callout-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .callout-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .callout--info .callout-icon { color: var(--blog-text-secondary); }
  .callout--tip .callout-icon { color: var(--blog-accent); }
  .callout--warning .callout-icon { color: var(--blog-warning, #f59e0b); }
  .callout-title {
    font-weight: 600;
    color: var(--blog-text-primary);
    font-size: 13px;
  }
  .callout-body {
    color: var(--blog-text-secondary);
  }
</style>
