---
// src/components/mealforge/Logo.astro
// The Skillet mark — top-down rosemary-green pan with a butter-pat accent,
// in a cast-iron container. Always renders dark regardless of theme.
// Keep in sync with public/favicon-mealforge.svg.
interface Props {
  size?: number;
  class?: string;
}

const { size = 30, class: className } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 120 120" fill="none" class={className} aria-label="Mealforge logo">
  <rect width="120" height="120" rx="26" fill="#23312a"/>
  <circle cx="52" cy="60" r="27" fill="#7fae8f"/>
  <circle cx="52" cy="60" r="19" fill="#2e523c"/>
  <rect x="74" y="54.5" width="32" height="11" rx="5.5" fill="#7fae8f"/>
  <rect x="46" y="54" width="12" height="12" rx="3" fill="#f0be3a"/>
</svg>
