---
// src/components/loosewire/Nav.astro
import Logo from './Logo.astro';
---
<nav class="lw-nav">
  <a href="/" class="lw-nav-home" aria-label="Loose Wire home">
    <Logo size={36} />
    <span class="lw-nav-wordmark">loosewire</span>
  </a>
  <div class="lw-nav-links">
    <slot />
  </div>
</nav>

<style>
  .lw-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--lw-paper);
    border-bottom: 1px solid var(--lw-rule-strong);
    padding: 10px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .lw-nav-home {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .lw-nav-wordmark {
    font-family: var(--lw-font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--lw-ink);
  }
  .lw-nav-links {
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .lw-nav-links :global(a) {
    font-family: var(--lw-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lw-ash);
    text-decoration: none;
    transition: color 0.12s;
  }
  .lw-nav-links :global(a:hover) {
    color: var(--lw-ink);
  }
</style>
