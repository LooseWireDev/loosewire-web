---
// src/components/loosewire/Wordmark.astro
// Horizontal lockup: W-wave mark + "loosewire" in Courier Prime bold.
import Logo from './Logo.astro';

interface Props {
  logoSize?: number;
  fontSize?: string;
  class?: string;
}

const { logoSize = 44, fontSize = '22px', class: className } = Astro.props;
---
<div class:list={['lw-wordmark', className]}>
  <Logo size={logoSize} />
  <span class="lw-wordmark-text" style={`font-size: ${fontSize};`}>loosewire</span>
</div>

<style>
  .lw-wordmark {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  .lw-wordmark-text {
    font-family: var(--lw-font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--lw-ink);
    line-height: 1;
  }
</style>
