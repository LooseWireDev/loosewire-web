---
// src/components/loosewire/FooterCredit.astro
import Logo from './Logo.astro';
---
<div class="lw-footer-credit">
  <div class="lw-footer-credit-left">
    <Logo size={30} />
    <span class="lw-footer-credit-text">loosewire.dev</span>
  </div>
  <slot />
</div>

<style>
  .lw-footer-credit {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .lw-footer-credit-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .lw-footer-credit-text {
    font-family: var(--lw-font-mono);
    font-size: 10px;
    letter-spacing: 0.10em;
    color: var(--lw-dust);
  }
</style>
