---
// src/components/loosewire/Logo.astro
// The Loose Wire W-wave mark. size = width in px; height scales at 100/180 ratio.
interface Props {
  size?: number;
  class?: string;
  color?: string;
}

const { size = 48, class: className, color } = Astro.props;
const h = Math.round(size * 100 / 180);
const strokeColor = color ?? 'var(--lw-ink)';
---
<svg
  width={size}
  height={h}
  viewBox="0 0 180 100"
  fill="none"
  class={className}
  aria-label="Loose Wire mark"
>
  <path
    d="M6 10 C18 10 18 90 33 90 C50 90 50 10 66 10 C82 10 82 90 99 90 C116 90 116 10 128 10"
    stroke={strokeColor}
    stroke-width="3.5"
    stroke-linecap="round"
    opacity="0.30"
  />
  <path
    d="M18 10 C34 10 34 90 51 90 C68 90 68 10 84 10 C100 10 100 90 117 90 C134 90 134 10 150 10"
    stroke={strokeColor}
    stroke-width="3.5"
    stroke-linecap="round"
    opacity="0.60"
  />
  <path
    d="M32 10 C48 10 48 90 69 90 C88 90 88 10 102 10 C116 10 116 90 135 90 C152 90 152 10 172 10"
    stroke={strokeColor}
    stroke-width="4"
    stroke-linecap="round"
    opacity="1"
  />
</svg>
