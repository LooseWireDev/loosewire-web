---
// src/components/farscry/Footer.astro
import Logo from '../loosewire/Logo.astro';
---
<footer class="fc-footer">
  <div class="fc-footer-inner">
    <div class="fc-footer-brand">
      <p class="fc-footer-name">Farscry</p>
      <p class="fc-footer-by">
        by
        <Logo size={12} />
        <a href="/" class="fc-footer-parent">loosewire</a>
      </p>
    </div>
    <nav class="fc-footer-nav">
      <a href="/farscry/blog">Blog</a>
      <a href="https://github.com/LooseWireDev/farscry">GitHub</a>
      <a href="mailto:info@loosewire.dev">Contact</a>
    </nav>
  </div>
</footer>

<style>
  .fc-footer {
    border-top: 1px solid var(--fc-border-subtle);
    padding: 40px 32px;
  }
  .fc-footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }
  .fc-footer-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--fc-text-primary);
    margin-bottom: 4px;
  }
  .fc-footer-by {
    font-size: 13px;
    color: var(--fc-text-tertiary);
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .fc-footer-parent {
    font-family: var(--lw-font-display, 'Nunito Sans', sans-serif);
    font-size: 12px;
    font-weight: 600;
    color: var(--fc-text-tertiary);
    text-decoration: none;
  }
  .fc-footer-nav {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .fc-footer-nav a {
    font-size: 13px;
    color: var(--fc-text-secondary);
    text-decoration: none;
  }
</style>
