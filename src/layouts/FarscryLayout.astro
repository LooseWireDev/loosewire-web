---
// src/layouts/FarscryLayout.astro
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  schema?: object;
  noindex?: boolean;
  articleMeta?: { publishedTime?: string; modifiedTime?: string; section?: string };
}

const { title, description, canonicalUrl, ogImage, ogType, schema, noindex, articleMeta } = Astro.props;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, 'https://loosewire.dev').href;
const image = ogImage ?? 'https://loosewire.dev/og-farscry.png';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon-farscry.svg" />

  <!-- Auto theme: set before any CSS to avoid flash -->
  <script is:inline>
    (function() {
      const t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', t);
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
        document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
      });
    })();
  </script>

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <meta property="og:site_name" content="Farscry by Loose Wire" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={image} />
  <meta property="og:type" content={ogType ?? 'website'} />
  <meta property="og:locale" content="en_US" />
  {articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
  {articleMeta?.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
  {articleMeta?.section && <meta property="article:section" content={articleMeta.section} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Farscry Blog" href="/farscry/rss.xml" />
</head>
<body style="background: var(--fc-bg); color: var(--fc-text-primary); font-family: 'Geist', system-ui, sans-serif;">
  <slot />
</body>
<style>
  body {
    --blog-accent:         var(--fc-violet);
    --blog-accent-subtle:  var(--fc-violet-subtle);
    --blog-accent-border:  rgba(167,139,250,0.2);
    --blog-text-primary:   var(--fc-text-primary);
    --blog-text-secondary: var(--fc-text-secondary);
    --blog-text-tertiary:  var(--fc-text-tertiary);
    --blog-surface-1:      var(--fc-surface-1);
    --blog-surface-2:      var(--fc-surface-2);
    --blog-border:         var(--fc-border);
    --blog-border-subtle:  var(--fc-border-subtle);
    --blog-error:          #f87171;
    --blog-warning:        #f59e0b;
  }
</style>
</html>
